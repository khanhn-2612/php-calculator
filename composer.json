{
    "name": "khanhn/php-calculator",
    "description": "A basic calculator package for Laravel",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "khanhn",
            "email": "khanhn@mynavitechtus.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "illuminate/support": "^9.0|^10.0|^11.0"
    },
    "require-dev": {
        "orchestra/testbench": "^7.0|^8.0|^9.0",
        "phpunit/phpunit": "^9.0|^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "KhanhN\\Calculator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KhanhN\\Calculator\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "KhanhN\\Calculator\\CalculatorServiceProvider"
            ],
            "aliases": {
                "Calculator": "KhanhN\\Calculator\\Facades\\Calculator"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
